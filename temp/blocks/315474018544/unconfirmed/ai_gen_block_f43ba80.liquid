{% doc %}
  @prompt
    Create a custom rich text heading block for the homepage. The heading text is "Welcome to Adventure Club Part — Where Every Drive Starts Right". Style it with an orange color (#e06820) with a subtle orange glow text-shadow effect. The background should be dark navy (#142240). The text should be large, bold, centered, and look premium. Match the existing Dawn theme section styling.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-rich-heading-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-rich-heading__text-{{ ai_gen_id }} {
    margin: 0;
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    color: {{ block.settings.text_color }};
    line-height: {{ block.settings.line_height }};
    text-shadow: {{ block.settings.glow_horizontal }}px {{ block.settings.glow_vertical }}px {{ block.settings.glow_blur }}px {{ block.settings.glow_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-rich-heading__text-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.font_size }}px * 0.7);
    }
  }
{% endstyle %}

<rich-heading-{{ ai_gen_id }} class="ai-rich-heading-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading_text != blank %}
    <h2 class="ai-rich-heading__text-{{ ai_gen_id }}">
      {{ block.settings.heading_text }}
    </h2>
  {% else %}
    <h2 class="ai-rich-heading__text-{{ ai_gen_id }}">
      Add your heading text
    </h2>
  {% endif %}
</rich-heading-{{ ai_gen_id }}>

<script>
  (function() {
    class RichHeading{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }
    customElements.define('rich-heading-{{ ai_gen_id }}', RichHeading{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Rich text heading",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading_text",
      "label": "Heading text",
      "default": "Welcome to Adventure Club Part — Where Every Drive Starts Right"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        },
        {
          "value": "800",
          "label": "Extra bold"
        }
      ],
      "default": "700"
    },
    {
      "type": "range",
      "id": "line_height",
      "label": "Line height",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "default": 1.2
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#e06820"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#142240"
    },
    {
      "type": "header",
      "content": "Glow effect"
    },
    {
      "type": "color",
      "id": "glow_color",
      "label": "Glow color",
      "default": "#e06820"
    },
    {
      "type": "range",
      "id": "glow_blur",
      "label": "Glow blur",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "glow_horizontal",
      "label": "Glow horizontal offset",
      "min": -10,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "glow_vertical",
      "label": "Glow vertical offset",
      "min": -10,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Padding horizontal",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Rich text heading"
    }
  ]
}
{% endschema %}
